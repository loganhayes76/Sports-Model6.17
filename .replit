modules = ["nodejs-20", "python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = [
  "glibcLocales",
  "libxcrypt",
  "pkg-config",
  "xsimd",
  "python313Packages.uvicorn",
]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Data Scheduler"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash run_dev.sh"
waitForPort = 5000

[[workflows.workflow]]
name = "Data Scheduler"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python scheduler.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "vm"
run = ["python3", "start_prod.py"]
build = ["bash", "build.sh"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 300000

[userenv]

[userenv.shared]
